{% set form = hookable_metadata.context.form.gatewayConfig.config.enable_express_checkout %}

<div class="col-12">
    {{ form_row(form, sylius_test_form_attribute('enable-express-checkout')) }}
</div>
<div class="col-12 alert alert-info {{ form.vars.data ? '' : ' d-none' }}" {{ sylius_test_html_attribute('enable-express-checkout-info') }}>
    <div class="d-flex align-items-center">
        <div>{{ ux_icon('tabler:info-circle', {'class': 'icon alert-icon'}) }}</div>
        <div>
            <p>
                {{ 'flux_se_sylius_stripe_plugin.form.gateway_configuration.stripe.info.enable_express_checkout'|trans }}
            </p>
            <p>
                <a href="https://docs.stripe.com/elements/express-checkout-element" target="_blank" rel="noopener noreferrer">
                    {{ 'sylius.ui.view_more'|trans }}
                </a>
            </p>
        </div>
    </div>
</div>
